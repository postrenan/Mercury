<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:loc="clr-namespace:Mercury.Editor.Localization"
        xmlns:ctrl="clr-namespace:Mercury.Editor.Controls"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Mercury.Editor.Views.ExecuteView.MonitorWindow"
        Title="{loc:MonitorResources WindowTitle}"
        Background="{DynamicResource BackgroundGrey}">
    <Grid Margin="5">
        <ctrl:PixelScreen x:Name="Screen"/>
    </Grid>
</Window>
