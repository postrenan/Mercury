<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Mercury.Editor.ViewModels.Code"
             xmlns:cv="clr-namespace:Mercury.Editor.Converters"
             mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="720"
             xmlns:codeView="clr-namespace:Mercury.Editor.Views.CodeView"
             x:DataType="vm:CodeTabViewModel"
             x:Class="Mercury.Editor.Views.CodeView.CodeTabView">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{Binding GuideColumnWidth, Mode=TwoWay,
                              Converter={x:Static cv:GridSizeConverter.Instance}}"
                              MaxWidth="500" MinWidth="100"/>
            <ColumnDefinition Width="2"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="2"/>
            <ColumnDefinition Width="{Binding ProjectViewColumnWidth, Mode=TwoWay,
                              Converter={x:Static cv:GridSizeConverter.Instance}}"
                              MaxWidth="500" MinWidth="100"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="2"/>
            <RowDefinition Height="{Binding ProblemsViewRowHeight, Mode=TwoWay,
                           Converter={x:Static cv:GridSizeConverter.Instance}}"
                           MinHeight="100" MaxHeight="300"/>
        </Grid.RowDefinitions>
        
        <!-- guide -->
        <codeView:GuideView Grid.Column="4" Grid.Row="0" Grid.RowSpan="3"/>

        <GridSplitter Grid.Column="3" Grid.Row="0" Grid.RowSpan="3" ResizeDirection="Columns"/>
        
        <!-- problems window -->
        <codeView:ProblemsView Grid.Column="0" Grid.Row="2" Grid.ColumnSpan="3"/>
        
        <GridSplitter Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="3" ResizeDirection="Rows"/>
        
        <!-- project window -->
        <codeView:ProjectView Grid.Column="0" Grid.Row="0"/>
        
        <GridSplitter Grid.Column="1" Grid.Row="0" ResizeDirection="Columns"/>
        
        <!-- open files window & toolbar -->
        <codeView:FileEditorView Grid.Row="0" Grid.Column="2" Background="{DynamicResource BackgroundGrey}"/>
    </Grid>
</UserControl>
