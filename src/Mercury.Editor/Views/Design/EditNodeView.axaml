<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="Mercury.Editor.Views.Design.EditNodeView"
        Background="{DynamicResource BackgroundGrey}"
        Width="600" Height="700"
        d:DesignWidth="600" d:DesignHeight="700"
        Title="Edit Node">
    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,*,Auto"
            Margin="10"
          ShowGridLines="True">
        <!-- name -->
        <StackPanel Grid.Column="0" Grid.Row="0" 
                    Margin="5">
            <Label Content="Name" Target="NameTextbox"/>
            <TextBox x:Name="NameTextbox"/>
        </StackPanel>
        <!-- sequential -->
        <StackPanel Grid.Column="1" Grid.Row="0" 
                    Margin="5">
            <Label Content="Sequential Component" Target="SequentialCheckbox"/>
            <CheckBox x:Name="SequentialCheckbox"
                      VerticalAlignment="Center"/>
        </StackPanel>
        <!-- inputs -->
        <StackPanel Grid.Column="0" Grid.Row="1"
                    HorizontalAlignment="Stretch"
                    Margin="5">
            <Label Content="Inputs" Target="InputDataGrid"/>
            <DataGrid x:Name="InputDataGrid" HorizontalAlignment="Stretch" Height="200"></DataGrid>
        </StackPanel>
        <!-- outputs -->
        <StackPanel Grid.Column="1" Grid.Row="1"
                    Margin="5"
                    HorizontalAlignment="Stretch">
            <Label Content="Outputs" Target="OutputDataGrid"/>
            <DataGrid x:Name="OutputDataGrid" HorizontalAlignment="Stretch" Height="200"></DataGrid>
        </StackPanel>
        <!-- editor -->
        <Grid Grid.Column="0" Grid.Row="2" Grid.ColumnSpan="2" RowDefinitions="Auto,*" Margin="5">
                <Label Grid.Row="0" Content="Behaviour" Target="BehaviourTextbox"/>
                <TextBox x:Name="BehaviourTextbox" Grid.Row="1"/>
                
        </Grid>
        <!-- action buttons -->
        <Button Grid.Column="0" Grid.Row="3" Content="Cancel"
                HorizontalAlignment="Left"/>
        <Button Grid.Column="1" Grid.Row="3" Content="Apply"
                HorizontalAlignment="Right"/>
    </Grid>
</Window>
